# === DJANGO ===
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ORIGINS=http://localhost:5173

# === DATABASE ===
DATABASE_URL=postgresql://devmind:devmind_secret@postgres:5432/devmind

# === REDIS / CELERY ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === GITHUB OAuth ===
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your-webhook-hmac-secret

# === OPENAI ===
OPENAI_API_KEY=sk-proj-xxxxx
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === FASTAPI SERVICE ===
FASTAPI_INTERNAL_SECRET=internal-service-token-here
FASTAPI_BASE_URL=http://fastapi:8001
FASTAPI_TIMEOUT_SECONDS=60
FASTAPI_DATABASE_URL=postgresql+asyncpg://devmind:devmind_secret@postgres:5432/devmind

# === SENTRY ===
SENTRY_DSN_DJANGO=https://xxxx@o0.ingest.sentry.io/0
SENTRY_DSN_FASTAPI=https://xxxx@o0.ingest.sentry.io/1
SENTRY_ENVIRONMENT=development

# === JWT ===
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# === AWS (for production) ===
AWS_REGION=us-east-1
AWS_S3_BUCKET=devmind-media-prod
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === PROMETHEUS / GRAFANA ===
GRAFANA_ADMIN_PASSWORD=admin_secret_here

# === RATE LIMITING ===
REVIEW_RATE_LIMIT_PER_HOUR=20
API_GLOBAL_RATE_LIMIT=1000
